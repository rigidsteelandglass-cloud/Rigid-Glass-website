---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { site } from '../config';
---

<Layout title="Our Work" description={`A gallery of custom glass and steel projects by ${site.legalName}.`}>
  <section class="mx-auto max-w-6xl px-5 pt-14 pb-2 text-center">
    <p class="eyebrow text-red">Our Work</p>
    <h1 class="mt-2 font-display text-4xl font-900 uppercase tracking-tight text-ink sm:text-5xl">The Gallery</h1>
    <p class="mx-auto mt-3 max-w-xl text-lg text-ink-soft">
      A look at recent custom glass and steel projects across {site.serviceArea}. Tap any photo to enlarge.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-10">
    <GalleryGrid />
  </section>
</Layout>
