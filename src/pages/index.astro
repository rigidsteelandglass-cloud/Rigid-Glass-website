---
import Layout from '../layouts/Layout.astro';
import { site, categories, features } from '../config';
import GalleryGrid from '../components/GalleryGrid.astro';

const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
// ponytail: hero + category art stay static so the fold paints instantly.
// Only the gallery is live from Supabase. Swap these to live photos if Noah
// asks to control them too.
const heroImg = '/gallery/seed-1.svg';
---

<Layout>
  <!-- Hero -->
  <section class="border-b border-stone">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 pb-12 pt-14 lg:grid-cols-2 lg:pt-20">
      <div>
        <p class="eyebrow inline-flex items-center gap-2 text-red">
          <span class="h-1.5 w-1.5 rounded-full bg-red"></span>
          Proudly serving {site.serviceArea}
        </p>
        <h1 class="mt-4 font-display text-5xl font-900 uppercase leading-[0.95] tracking-tight text-ink sm:text-6xl">
          Handcrafted.<br /><span class="text-red">Built Rigid.</span>
        </h1>
        <p class="mt-5 max-w-md text-lg text-ink-soft">{site.intro}</p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={telHref} class="rounded-lg bg-red px-6 py-3 text-sm font-700 text-white shadow-sm transition-colors hover:bg-red-deep">
            Call / Text {site.phone}
          </a>
          <a href="/work" class="rounded-lg border border-ink/15 bg-white px-6 py-3 text-sm font-700 text-ink transition-colors hover:border-red hover:text-red">
            See our work
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="aspect-[4/5] overflow-hidden rounded-2xl border border-stone bg-mist shadow-xl">
          <img src={heroImg} alt="RIGID custom glass work" class="h-full w-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Feature badges -->
  <section class="border-b border-stone bg-mist">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-8 gap-y-3 px-5 py-6 text-center">
      {features.map((f) => (
        <span class="eyebrow text-ink-soft">{f}</span>
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="text-center">
      <p class="eyebrow text-red">What we do</p>
      <h2 class="mt-2 font-display text-3xl font-800 uppercase tracking-tight text-ink sm:text-4xl">Custom Steel &amp; Glass</h2>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {categories.map((c, i) => (
        <a href={`/services/${c.slug}`} class="reveal group overflow-hidden rounded-2xl border border-stone bg-white shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl">
          <div class="aspect-[4/3] overflow-hidden bg-mist">
            <img src={c.image} alt={c.name} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="p-6">
            <h3 class="font-display text-lg font-800 uppercase tracking-wide text-ink">{c.name}</h3>
            <p class="mt-2 text-sm text-ink-soft">{c.blurb}</p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-700 text-red">
              Learn more
              <svg class="transition-transform group-hover:translate-x-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Recent work -->
  <section class="border-t border-stone bg-mist">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="eyebrow text-red">Recent projects</p>
          <h2 class="mt-2 font-display text-3xl font-800 uppercase tracking-tight text-ink sm:text-4xl">Latest builds</h2>
        </div>
        <a href="/work" class="hidden shrink-0 text-sm font-700 text-red hover:underline sm:inline">View all →</a>
      </div>
      <div class="mt-8">
        <GalleryGrid source="recent" limit={6} />
      </div>
      <div class="mt-10 text-center">
        <a href="/work" class="group inline-flex items-center gap-2 rounded-lg bg-ink px-6 py-3 text-sm font-700 text-white transition-colors hover:bg-red">
          View all work
          <svg class="transition-transform group-hover:translate-x-1" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="overflow-hidden rounded-2xl bg-ink px-8 py-12 text-center text-white sm:px-16">
      <h2 class="font-display text-3xl font-800 uppercase tracking-tight sm:text-4xl">Get a free quote</h2>
      <p class="mx-auto mt-3 max-w-lg text-white/70">Tell {site.owner.split(' ')[0]} about your project — call or text and we’ll get right back to you.</p>
      <a href={telHref} class="mt-7 inline-block rounded-lg bg-red px-7 py-3 text-sm font-700 text-white transition-colors hover:bg-red-deep">
        Call / Text {site.phone}
      </a>
      <p class="mt-5 eyebrow text-white/50">{site.closer}</p>
    </div>
  </section>
</Layout>
