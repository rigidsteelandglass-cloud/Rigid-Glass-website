---
import Layout from '../../layouts/Layout.astro';
import { site, categories } from '../../config';
import GalleryGrid from '../../components/GalleryGrid.astro';
import CoverImage from '../../components/CoverImage.astro';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.slug }, props: { c } }));
}

const { c } = Astro.props;
const others = categories.filter((x) => x.slug !== c.slug);
const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
---

<Layout title={c.name} description={c.blurb}>
  <section class="mx-auto max-w-6xl px-5 pt-12">
    <a href="/services" class="inline-flex items-center gap-1 text-sm font-700 text-red hover:underline">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
      All services
    </a>

    <div class="mt-6 grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="eyebrow text-red">Service</p>
        <h1 class="mt-2 font-display text-4xl font-900 uppercase tracking-tight text-ink sm:text-5xl">{c.name}</h1>
        <p class="mt-4 text-lg text-ink-soft">{c.blurb}</p>
        <p class="mt-3 text-ink-soft">
          Every job is custom-measured and built to last — {site.motto.toLowerCase()} Serving {site.serviceArea}.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={telHref} class="rounded-lg bg-red px-6 py-3 text-sm font-700 text-white transition-colors hover:bg-red-deep">Call / Text {site.phone}</a>
          <a href="/work" class="rounded-lg border border-ink/15 bg-white px-6 py-3 text-sm font-700 text-ink transition-colors hover:border-red hover:text-red">See our work</a>
        </div>
      </div>
      <div class="aspect-[4/3] overflow-hidden rounded-2xl border border-stone bg-mist shadow-lg">
        <CoverImage slot={c.slug} fallback={c.image} alt={c.name} />
      </div>
    </div>
  </section>

  <!-- This category's photos -->
  <section class="border-t border-stone bg-mist">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <p class="eyebrow text-red">Recent {c.name.toLowerCase()} projects</p>
      <h2 class="mt-2 font-display text-3xl font-800 uppercase tracking-tight text-ink sm:text-4xl">
        The work
      </h2>
      <div class="mt-8">
        <GalleryGrid source={c.slug} empty={`New ${c.name.toLowerCase()} photos are on the way — check back soon.`} />
      </div>
    </div>
  </section>

  <!-- Other services -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <p class="eyebrow text-red">Also from RIGID</p>
    <div class="mt-5 grid gap-6 sm:grid-cols-2">
      {others.map((o) => (
        <a href={`/services/${o.slug}`} class="group flex items-center gap-5 rounded-2xl border border-stone bg-white p-4 transition-all hover:-translate-y-0.5 hover:shadow-md">
          <div class="h-20 w-24 shrink-0 overflow-hidden rounded-lg bg-mist">
            <CoverImage slot={o.slug} fallback={o.image} alt={o.name} />
          </div>
          <div>
            <h3 class="font-display text-lg font-800 uppercase tracking-wide text-ink">{o.name}</h3>
            <span class="mt-1 inline-flex items-center gap-1 text-sm font-700 text-red">View
              <svg class="transition-transform group-hover:translate-x-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
