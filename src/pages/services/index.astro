---
import Layout from '../../layouts/Layout.astro';
import { site, categories } from '../../config';

const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
---

<Layout title="Services" description={`Custom glass, handrailing, and European shower doors. Serving ${site.serviceArea}.`}>
  <section class="mx-auto max-w-6xl px-5 pt-14 text-center">
    <p class="eyebrow text-red">Our Services</p>
    <h1 class="mt-2 font-display text-4xl font-900 uppercase tracking-tight text-ink sm:text-5xl">
      What We Build
    </h1>
    <p class="mt-3 inline-flex items-center gap-2 text-lg text-ink-soft">
      <svg class="text-red" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5Z"/></svg>
      Proudly serving {site.serviceArea}
    </p>
  </section>

  <!-- Category cards -->
  <section class="mx-auto max-w-6xl px-5 py-12">
    <div class="grid gap-8 md:grid-cols-3">
      {categories.map((c, i) => (
        <a href={`/services/${c.slug}`} class="reveal group flex flex-col overflow-hidden rounded-2xl border border-stone bg-white shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl">
          <div class="aspect-[4/3] overflow-hidden bg-mist">
            <img src={c.image} alt={c.name} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h2 class="font-display text-xl font-800 uppercase tracking-wide text-ink">{c.name}</h2>
            <p class="mt-2 flex-1 text-sm text-ink-soft">{c.blurb}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-700 text-red">
              View details
              <svg class="transition-transform group-hover:translate-x-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Service area -->
  <section class="border-y border-stone bg-mist">
    <div class="mx-auto max-w-6xl px-5 py-10 text-center">
      <p class="eyebrow text-red">Where we work</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-x-3 gap-y-2">
        {site.cities.map((city) => (
          <span class="rounded-full border border-stone bg-white px-4 py-1.5 text-sm font-600 text-ink">{city}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-5 py-16 text-center">
    <h2 class="font-display text-3xl font-800 uppercase tracking-tight text-ink">Ready to start?</h2>
    <p class="mx-auto mt-3 max-w-md text-ink-soft">Call or text for a free quote — {site.motto}</p>
    <a href={telHref} class="mt-6 inline-block rounded-lg bg-red px-7 py-3 text-sm font-700 text-white transition-colors hover:bg-red-deep">
      Call / Text {site.phone}
    </a>
  </section>
</Layout>
