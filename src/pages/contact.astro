---
import Layout from '../layouts/Layout.astro';
import { site } from '../config';

const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
---

<Layout title="Contact" description={`Request a free quote from ${site.businessName}.`}>
  <section class="mx-auto max-w-5xl px-5 pt-16">
    <p class="text-xs font-600 uppercase tracking-widest text-aqua-deep">Contact</p>
    <h1 class="mt-2 font-display text-4xl font-600 tracking-tight text-ink sm:text-5xl">Let’s talk about your project</h1>
    <p class="mt-3 max-w-xl text-lg text-ink-soft">
      Call or text {site.owner} directly, or send the details below and he’ll get back to you.
    </p>
  </section>

  <section class="mx-auto grid max-w-5xl gap-10 px-5 py-12 lg:grid-cols-5">
    <!-- Quick contact -->
    <div class="space-y-4 lg:col-span-2">
      <a href={telHref} class="flex items-center gap-4 rounded-2xl bg-white p-5 ring-1 ring-stone/70 transition-colors hover:ring-aqua">
        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-aqua-light text-aqua-deep">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        </span>
        <span>
          <span class="block text-xs font-600 uppercase tracking-widest text-ink-soft">Call or text</span>
          <span class="block font-display text-lg font-600 text-ink">{site.phone}</span>
        </span>
      </a>

      <a href={`mailto:${site.email}`} class="flex items-center gap-4 rounded-2xl bg-white p-5 ring-1 ring-stone/70 transition-colors hover:ring-aqua">
        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-aqua-light text-aqua-deep">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
        </span>
        <span>
          <span class="block text-xs font-600 uppercase tracking-widest text-ink-soft">Email</span>
          <span class="block font-display text-lg font-600 text-ink">{site.email}</span>
        </span>
      </a>

      <div class="rounded-2xl bg-mist p-5 text-sm text-ink-soft ring-1 ring-stone/70">
        Serving {site.serviceArea}. Free quotes, no pressure.
      </div>
    </div>

    <!-- Form (Netlify Forms — submissions are emailed to Noah, no server code needed) -->
    <div class="lg:col-span-3">
      <form
        name="quote"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/thanks"
        class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-stone/70 sm:p-8"
      >
        <input type="hidden" name="form-name" value="quote" />
        <p class="hidden">
          <label>Don’t fill this out: <input name="bot-field" /></label>
        </p>

        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block sm:col-span-1">
            <span class="text-sm font-600 text-ink">Name</span>
            <input required name="name" type="text" autocomplete="name" class="mt-1.5 w-full rounded-lg border border-stone bg-mist px-3.5 py-2.5 text-ink outline-none transition focus:border-aqua focus:ring-2 focus:ring-aqua/30" />
          </label>
          <label class="block sm:col-span-1">
            <span class="text-sm font-600 text-ink">Phone</span>
            <input name="phone" type="tel" autocomplete="tel" class="mt-1.5 w-full rounded-lg border border-stone bg-mist px-3.5 py-2.5 text-ink outline-none transition focus:border-aqua focus:ring-2 focus:ring-aqua/30" />
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm font-600 text-ink">Email</span>
            <input required name="email" type="email" autocomplete="email" class="mt-1.5 w-full rounded-lg border border-stone bg-mist px-3.5 py-2.5 text-ink outline-none transition focus:border-aqua focus:ring-2 focus:ring-aqua/30" />
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm font-600 text-ink">Tell Noah about your project</span>
            <textarea required name="message" rows="5" placeholder="e.g. I’d like to convert my tub to a walk-in tile shower…" class="mt-1.5 w-full resize-y rounded-lg border border-stone bg-mist px-3.5 py-2.5 text-ink outline-none transition focus:border-aqua focus:ring-2 focus:ring-aqua/30"></textarea>
          </label>
        </div>

        <button type="submit" class="mt-6 w-full rounded-lg bg-ink px-6 py-3 text-sm font-600 text-mist transition-colors hover:bg-aqua-deep sm:w-auto">
          Send request
        </button>
        <p class="mt-3 text-xs text-ink-soft">Noah typically replies within a day.</p>
      </form>
    </div>
  </section>
</Layout>
