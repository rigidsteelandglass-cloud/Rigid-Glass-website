---
import Layout from '../layouts/Layout.astro';
import { site } from '../config';

const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
const smsHref = `sms:${site.phone.replace(/[^0-9+]/g, '')}`;
---

<Layout title="Contact" description={`Request a free quote from ${site.legalName}.`}>
  <section class="mx-auto max-w-5xl px-5 pt-14 text-center">
    <p class="eyebrow text-red">Contact</p>
    <h1 class="mt-2 font-display text-4xl font-900 uppercase tracking-tight text-ink sm:text-5xl">Request a Quote</h1>
    <p class="mx-auto mt-3 max-w-xl text-lg text-ink-soft">
      Call or text {site.owner.split(' ')[0]} directly, or send the details below and we’ll get right back to you.
    </p>
  </section>

  <section class="mx-auto grid max-w-5xl gap-10 px-5 py-12 lg:grid-cols-5">
    <!-- Quick contact -->
    <div class="space-y-4 lg:col-span-2">
      <a href={telHref} class="flex items-center gap-4 rounded-2xl border border-stone bg-white p-5 transition-colors hover:border-red">
        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-red-soft text-red">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        </span>
        <span>
          <span class="eyebrow block text-ink-soft">Call</span>
          <span class="block font-display text-lg font-800 text-ink">{site.phone}</span>
        </span>
      </a>

      <a href={smsHref} class="flex items-center gap-4 rounded-2xl border border-stone bg-white p-5 transition-colors hover:border-red">
        <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-red-soft text-red">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z"/></svg>
        </span>
        <span>
          <span class="eyebrow block text-ink-soft">Text us</span>
          <span class="block font-display text-lg font-800 text-ink">{site.phone}</span>
        </span>
      </a>

      <div class="rounded-2xl border border-stone bg-mist p-5 text-sm text-ink-soft">
        <p class="font-600 text-ink">Proudly serving {site.serviceArea}</p>
        <p class="mt-1">{site.cities.join(' · ')}</p>
        <p class="mt-3">Free quotes. {site.motto}</p>
      </div>
    </div>

    <!-- Form (Netlify Forms — emails the submission to Noah, no server code) -->
    <div class="lg:col-span-3">
      <form
        name="quote"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/thanks"
        class="rounded-2xl border border-stone bg-white p-6 shadow-sm sm:p-8"
      >
        <input type="hidden" name="form-name" value="quote" />
        <p class="hidden"><label>Don’t fill this out: <input name="bot-field" /></label></p>

        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-700 text-ink">Name</span>
            <input required name="name" type="text" autocomplete="name" class="mt-1.5 w-full rounded-lg border border-stone bg-mist px-3.5 py-2.5 text-ink outline-none transition focus:border-red focus:ring-2 focus:ring-red/25" />
          </label>
          <label class="block">
            <span class="text-sm font-700 text-ink">Phone</span>
            <input name="phone" type="tel" autocomplete="tel" class="mt-1.5 w-full rounded-lg border border-stone bg-mist px-3.5 py-2.5 text-ink outline-none transition focus:border-red focus:ring-2 focus:ring-red/25" />
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm font-700 text-ink">Email <span class="font-400 text-steel">(optional)</span></span>
            <input name="email" type="email" autocomplete="email" class="mt-1.5 w-full rounded-lg border border-stone bg-mist px-3.5 py-2.5 text-ink outline-none transition focus:border-red focus:ring-2 focus:ring-red/25" />
          </label>
          <label class="block sm:col-span-2">
            <span class="text-sm font-700 text-ink">What can we build for you?</span>
            <textarea required name="message" rows="5" placeholder="e.g. A frameless glass shower enclosure, glass stair railing, storefront glass…" class="mt-1.5 w-full resize-y rounded-lg border border-stone bg-mist px-3.5 py-2.5 text-ink outline-none transition focus:border-red focus:ring-2 focus:ring-red/25"></textarea>
          </label>
        </div>

        <button type="submit" class="mt-6 w-full rounded-lg bg-red px-6 py-3 text-sm font-700 text-white transition-colors hover:bg-red-deep sm:w-auto">
          Send request
        </button>
        <p class="mt-3 text-xs text-ink-soft">We typically reply within a day.</p>
      </form>
    </div>
  </section>
</Layout>
