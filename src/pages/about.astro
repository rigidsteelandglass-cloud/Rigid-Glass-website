---
import Layout from '../layouts/Layout.astro';
import { site, features } from '../config';

const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
const firstName = site.owner.split(' ')[0];
---

<Layout title="About" description={`Meet ${site.owner}, the craftsman behind ${site.legalName}.`}>
  <section class="mx-auto max-w-5xl px-5 pt-14">
    <div class="grid items-center gap-10 lg:grid-cols-5">
      <div class="lg:col-span-3">
        <p class="eyebrow text-red">About</p>
        <h1 class="mt-2 font-display text-4xl font-900 uppercase tracking-tight text-ink sm:text-5xl">
          Built Rigid.
        </h1>
        <div class="mt-5 space-y-4 text-lg text-ink-soft">
          <p>
            I’m {site.owner}, the owner of {site.legalName}. We specialize in custom glass and steel —
            glass railings, European shower doors, storefront glass, and custom metal-and-glass work
            across {site.serviceArea}.
          </p>
          <p>
            Glass is a family trade for us. We’ve been building shower doors and railings together for
            years, and that experience shows up in every install — custom-measured panels that fit
            right, clean lines, and work that’s built to last.
          </p>
          <p>
            The company name is new, but the crew isn’t. {site.motto} If you’ve got a project in mind,
            we’d love to hear about it.
          </p>
        </div>
        <a href={telHref} class="mt-7 inline-block rounded-lg bg-red px-6 py-3 text-sm font-700 text-white transition-colors hover:bg-red-deep">
          Call / Text {firstName}
        </a>
      </div>

      <div class="lg:col-span-2">
        <div class="aspect-[4/5] overflow-hidden rounded-2xl border border-stone bg-mist shadow-xl">
          <img src="/gallery/seed-2.svg" alt={`${site.owner}’s glass work`} class="h-full w-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Feature badges -->
  <section class="mx-auto max-w-5xl px-5 py-16">
    <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {features.map((f) => (
        <div class="reveal rounded-xl border border-stone bg-white p-5 text-center">
          <p class="font-display text-sm font-800 uppercase tracking-wide text-ink">{f}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
