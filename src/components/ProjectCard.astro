---
interface Props {
  href: string;
  title: string;
  location?: string;
  summary: string;
  coverImage: string;
}
const { href, title, location, summary, coverImage } = Astro.props;
---

<a
  href={href}
  class="reveal group block overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-stone/70 transition-all hover:-translate-y-1 hover:shadow-xl hover:ring-aqua/40"
>
  <div class="aspect-[4/3] overflow-hidden bg-stone">
    <img
      src={coverImage}
      alt={`${title}${location ? ' in ' + location : ''}`}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  <div class="p-5">
    {
      location && (
        <p class="text-xs font-600 uppercase tracking-widest text-aqua-deep">{location}</p>
      )
    }
    <h3 class="mt-1 font-display text-xl font-600 text-ink">{title}</h3>
    <p class="mt-1.5 line-clamp-2 text-sm text-ink-soft">{summary}</p>
    <span class="mt-3 inline-flex items-center gap-1 text-sm font-600 text-aqua-deep">
      View project
      <svg class="transition-transform group-hover:translate-x-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </span>
  </div>
</a>
