---
import Logo from './Logo.astro';
import { site, categories } from '../config';
const year = new Date().getFullYear();
const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
---

<footer class="mt-24 border-t border-stone bg-mist">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div class="sm:col-span-2 lg:col-span-1">
      <Logo class="text-[52px]" />
      <p class="mt-4 max-w-xs text-sm text-ink-soft">{site.intro}</p>
    </div>

    <div>
      <p class="eyebrow text-red">Services</p>
      <ul class="mt-3 space-y-2 text-sm">
        {categories.map((c) => (
          <li><a class="text-ink-soft hover:text-red" href={`/services/${c.slug}`}>{c.name}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="eyebrow text-red">Explore</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-ink-soft hover:text-red" href="/work">Our Work</a></li>
        <li><a class="text-ink-soft hover:text-red" href="/about">About</a></li>
        <li><a class="text-ink-soft hover:text-red" href="/contact">Contact</a></li>
      </ul>
    </div>

    <div>
      <p class="eyebrow text-red">Get in touch</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="font-600 text-ink hover:text-red" href={telHref}>{site.phone}</a></li>
        <li><a class="break-all text-ink-soft hover:text-red" href={`mailto:${site.email}`}>{site.email}</a></li>
        <li class="text-ink-soft">Serving {site.serviceArea}</li>
        <li class="text-ink-soft">{site.cities.join(' · ')}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-stone">
    <div class="mx-auto flex max-w-6xl flex-col gap-1 px-5 py-5 text-xs text-steel sm:flex-row sm:items-center sm:justify-between">
      <span>© {year} {site.legalName}. All rights reserved.</span>
      <span class="font-display uppercase tracking-widest">{site.closer}</span>
    </div>
  </div>
</footer>
