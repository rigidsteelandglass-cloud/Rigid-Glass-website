---
/**
 * Renders the gallery from Supabase Storage in the browser, so new uploads go
 * live without a Netlify rebuild.
 *
 * `source` is a category slug, "all" (every category, in Noah's order), or
 * "recent" (newest uploads first — the home page).
 */
interface Props {
  source?: string;
  limit?: number;
  empty?: string;
}
const {
  source = 'all',
  limit = 200,
  empty = 'Photos are on the way — check back soon.',
} = Astro.props;
---

<div
  data-gallery
  data-source={source}
  data-limit={limit}
  data-empty={empty}
  class="[column-fill:_balance] gap-4 sm:columns-2 lg:columns-3"
>
  <!-- filled client-side; skeletons hold the space so the page doesn't jump -->
  {
    [0, 1, 2].map(() => (
      <div class="mb-4 h-56 w-full animate-pulse rounded-xl border border-stone bg-mist" />
    ))
  }
</div>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-ink/90 p-4 backdrop-blur-sm"
>
  <button id="lightbox-close" class="absolute right-5 top-5 text-white/80 hover:text-white" aria-label="Close">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[92vw] rounded-lg object-contain shadow-2xl" />
</div>

<script>
  import { listPhotos, allPhotos, recentPhotos } from '../lib/supabase';

  // querySelectorAll: a page may hold more than one grid (e.g. two categories).
  for (const grid of document.querySelectorAll<HTMLElement>('[data-gallery]')) {
    const limit = Number(grid.dataset.limit ?? 200);
    const source = grid.dataset.source ?? 'all';
    const photos = (
      source === 'recent'
        ? await recentPhotos(limit)
        : source === 'all'
          ? await allPhotos()
          : await listPhotos(source)
    ).slice(0, limit);
    grid.innerHTML = photos.length
      ? photos
          .map(
            (p) => `
        <button type="button" data-lightbox-src="${p.url}"
          class="group mb-4 block w-full overflow-hidden rounded-xl border border-stone bg-mist focus:outline-none focus-visible:ring-2 focus-visible:ring-red">
          <img src="${p.url}" alt="RIGID custom glass &amp; steel project" loading="lazy" decoding="async"
            class="w-full transition-transform duration-500 group-hover:scale-[1.03]" />
        </button>`
          )
          .join('')
      : `<p class="rounded-xl border border-dashed border-stone bg-mist p-10 text-center text-ink-soft">${grid.dataset.empty}</p>`;
  }

  const box = document.getElementById('lightbox');
  const img = document.getElementById('lightbox-img') as HTMLImageElement;
  const close = () => {
    box?.classList.add('hidden');
    box?.classList.remove('flex');
    document.body.style.overflow = '';
  };
  // delegated: photos are injected after this script runs
  document.addEventListener('click', (e) => {
    const el = (e.target as HTMLElement)?.closest('[data-lightbox-src]');
    if (!el) return;
    img.src = el.getAttribute('data-lightbox-src') || '';
    img.alt = 'RIGID custom glass & steel project';
    box?.classList.remove('hidden');
    box?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  });
  document.getElementById('lightbox-close')?.addEventListener('click', close);
  box?.addEventListener('click', (e) => {
    if (e.target === box) close();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>
