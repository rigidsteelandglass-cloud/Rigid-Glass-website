---
import Logo from './Logo.astro';
import { site, categories } from '../config';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
---

<header class="sticky top-0 z-50 border-b border-stone bg-paper/90 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3">
    <a href="/" class="shrink-0" aria-label={`${site.legalName} home`}>
      <Logo class="text-[32px] sm:text-[44px]" />
    </a>

    <div class="flex items-center gap-1 text-sm sm:gap-2">
      <a
        href="/work"
        class:list={['hidden rounded px-3 py-2 font-600 transition-colors sm:block', isActive('/work') ? 'text-red' : 'text-ink-soft hover:text-ink']}
      >Our Work</a>

      <!-- Services + dropdown (desktop hover) -->
      <div class="group relative hidden sm:block">
        <a
          href="/services"
          class:list={['flex items-center gap-1 rounded px-3 py-2 font-600 transition-colors', isActive('/services') ? 'text-red' : 'text-ink-soft hover:text-ink']}
        >
          Services
          <svg class="mt-0.5 transition-transform group-hover:rotate-180" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </a>
        <div class="invisible absolute left-0 top-full w-60 translate-y-1 pt-2 opacity-0 transition-all group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
          <div class="overflow-hidden rounded-xl border border-stone bg-paper shadow-xl">
            {categories.map((c) => (
              <a href={`/services/${c.slug}`} class="block border-b border-stone px-4 py-3 last:border-0 hover:bg-mist">
                <span class="font-display text-sm font-700 text-ink">{c.name}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <a
        href="/about"
        class:list={['hidden rounded px-3 py-2 font-600 transition-colors sm:block', isActive('/about') ? 'text-red' : 'text-ink-soft hover:text-ink']}
      >About</a>
      <a
        href="/contact"
        class:list={['hidden rounded px-3 py-2 font-600 transition-colors sm:block', isActive('/contact') ? 'text-red' : 'text-ink-soft hover:text-ink']}
      >Contact</a>

      <!-- Mobile condensed links -->
      <a href="/work" class="rounded px-2.5 py-2 font-600 text-ink-soft sm:hidden">Work</a>
      <a href="/services" class="rounded px-2.5 py-2 font-600 text-ink-soft sm:hidden">Services</a>

      <a
        href={telHref}
        class="ml-1 inline-flex items-center gap-2 rounded-lg bg-red px-4 py-2 font-700 text-white shadow-sm transition-colors hover:bg-red-deep"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        <span class="hidden xs:inline sm:inline">Get a Quote</span>
      </a>
    </div>
  </nav>
</header>
